{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "APK Compat Helper",
  "version": "0.1.7",
  "identifier": "com.pbrain.apkcompathelper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "APK Compat Helper",
        "width": 920,
        "height": 700,
        "minWidth": 760,
        "minHeight": 620,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 20
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/compatibility-catalog.json",
      "resources/tooling/common/*.jar"
    ]
  }
}
